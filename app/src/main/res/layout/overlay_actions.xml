<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayActionsRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_overlay_panel"
    android:elevation="8dp"
    android:orientation="vertical"
    android:padding="12dp">

    <Button
        android:id="@+id/actionRead"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Read aloud" />

    <Button
        android:id="@+id/actionSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Summarize" />

    <Button
        android:id="@+id/actionChat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Ask AI" />

    <Button
        android:id="@+id/actionClipboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Clipboard" />

    <Button
        android:id="@+id/actionStop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_outline_button"
        android:text="Stop overlay" />

</LinearLayout>
